# ============================================
# 出游计划自动规划多智能体平台 — 环境变量
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# --- LLM / 模型配置 ---
# 支持 OpenAI 官方、第三方 OpenAI 兼容接口、本地 Ollama / LM Studio / vLLM / Xinference
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# 兼容旧变量名；如果同时配置，LLM_* 优先
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# 本地模型示例：
# Ollama:    LLM_PROVIDER=ollama,   LLM_BASE_URL=http://127.0.0.1:11434/v1, LLM_MODEL=qwen2.5:7b, LLM_API_KEY=
# LM Studio: LLM_PROVIDER=lmstudio, LLM_BASE_URL=http://127.0.0.1:1234/v1,  LLM_MODEL=local-model, LLM_API_KEY=
# vLLM:      LLM_PROVIDER=vllm,     LLM_BASE_URL=http://127.0.0.1:8000/v1,  LLM_MODEL=your-served-model, LLM_API_KEY=

# --- Amadeus (机票+酒店，可选) ---
# 注册: https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# --- Tavily (搜索，可选) ---
# 注册: https://tavily.com
TAVILY_API_KEY=

# --- AMap / 高德地图（自驾路线，可选但推荐） ---
# 注册: https://lbs.amap.com
AMAP_API_KEY=

# --- Yelp Fusion (餐饮，可选) ---
# 注册: https://fusion.yelp.com
YELP_API_KEY=

# ============================================
# v2.0 新增配置 (FastAPI + 评估 + 记忆)
# ============================================

# --- 服务器 ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Agent 预算 ---
MAX_ORCHESTRATOR_ITERATIONS=90
MAX_SUBAGENT_ITERATIONS=50
MAX_CONCURRENT_SUBAGENTS=3

# --- 记忆系统 ---
MEMORY_WORKING_WINDOW=20
MEMORY_DB_PATH=./data/memory.db
SEMANTIC_MEMORY_PATH=./data/user_profile.json

# --- 评估系统 ---
EVAL_ENABLED=true
EVAL_AUTO_JUDGE=true
EVAL_AUTO_OPTIMIZE=false
EVAL_MODEL=
EVAL_DRIFT_THRESHOLD=0.2
EVAL_DRIFT_MIN_SAMPLES=3
EVAL_DB_PATH=./data/eval.db

# --- 证据系统 ---
EVIDENCE_DB_PATH=./data/evidence.db

# --- 工作区 ---
WORKSPACE_PATH=./output
